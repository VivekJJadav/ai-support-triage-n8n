    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const email = String($json.customer_email || '').trim().toLowerCase();\nconst subject = String($json.subject || '').trim();\nconst body = String($json.body || '').trim();\nconst source = String($json.source || 'unknown').trim();\n\nconst submittedAt = new Date();\nconst submittedAtIso = submittedAt.toISOString();\nconst submittedAtMs = submittedAt.getTime();\n\nconst normalizedSubject = subject\n  .toLowerCase()\n  .replace(/[^a-z0-9]+/g, '-')\n  .replace(/^-+|-+$/g, '');\n\nconst duplicateKey = `${email}|${normalizedSubject}`;\nconst cleanText = `${subject}\\n${body}`.replace(/\\s+/g, ' ').trim();\n\nconst ticketId = `tkt_${submittedAtMs}`;\n\nreturn {\n  json: {\n    ...$json,\n    ticket_id: ticketId,\n    submitted_at_iso: submittedAtIso,\n    submitted_at_epoch_ms: submittedAtMs,\n    clean_text: cleanText,\n    duplicate_key: duplicateKey,\n    status: 'new',\n    escalated: false\n  }\n};\n"
      },
