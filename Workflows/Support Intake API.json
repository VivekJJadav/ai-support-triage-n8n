    {
      "parameters": {
        "promptType": "define",
        "text": "=You are a support operations triage assistant.\n\nAnalyze the ticket below and return STRICT JSON only.\nDo not wrap the JSON in markdown.\nDo not include commentary.\n\nChoose exactly one value for each enum field.\n\nAllowed category values:\nbilling, bug, feature_request, account_access, integration, how_to, other\n\nAllowed urgency_label values:\nlow, medium, high, critical\n\nAllowed sentiment_label values:\nnegative, neutral, positive\n\nTicket:\nCustomer tier: {{$json.customer_tier}}\nCustomer email: {{$json.customer_email}}\nSource: {{$json.source}}\nSubject: {{$json.subject}}\nBody: {{$json.body}}\n\nReturn this exact JSON shape:\n{\n  \"category\": \"account_access\",\n  \"product_area\": \"\",\n  \"urgency_label\": \"medium\",\n  \"sentiment_label\": \"negative\",\n  \"language\": \"English\",\n  \"ai_summary\": \"\",\n  \"recommended_action\": \"\",\n  \"ai_reply_draft\": \"\",\n  \"confidence\": 0.0\n}\n",
        "batching": {}
      },
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        976,
        256
      ],
      "id": "09c62fb8-af88-4a86-bf56-3027d6d575b0",
      "name": "AI Triage"
    },
    {
      "parameters": {
        "model": "qwen2.5:0.5b",
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.lmChatOllama",
      "typeVersion": 1,
      "position": [
        1184,
        448
      ],
      "id": "cbd0bec6-4f74-401f-afe9-f50d8a0952c7",
      "name": "Ollama Chat Model",
      "credentials": {
        "ollamaApi": {
          "id": "DAhmXnKKg9XAA3Fe",
          "name": "Ollama account 3"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const raw = $json.output ?? $json.text ?? $json.response ?? '';\n\nlet parsed;\n\ntry {\n  parsed = typeof raw === 'string' ? JSON.parse(raw) : raw;\n} catch (error) {\n  const match = String(raw).match(/\\{[\\s\\S]*\\}/);\n\n  if (!match) {\n    throw new Error(`AI output was not valid JSON. Raw output: ${String(raw).slice(0, 500)}`);\n  }\n\n  parsed = JSON.parse(match[0]);\n}\n\nreturn {\n  json: parsed\n};\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1296,
        256
      ],
      "id": "7c67e968-7542-4834-8e2f-05782d4794b8",
      "name": "Parse AI JSON"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const original = $('Derive IDs and SLA Seed').first().json;\nconst ai = $json;\n\nlet score = 0;\n\nif (ai.urgency_label === 'critical') score += 50;\nelse if (ai.urgency_label === 'high') score += 35;\nelse if (ai.urgency_label === 'medium') score += 20;\nelse score += 10;\n\nif (ai.sentiment_label === 'negative') score += 15;\n\nconst text = `${original.subject} ${original.body}`.toLowerCase();\n\nif (/(outage|down|cannot login|cannot log in|billing broken|security|data loss|payment failed)/.test(text)) {\n  score += 35;\n}\n\nif (/(enterprise|annual contract|founder|ceo|vp)/.test(text)) {\n  score += 10;\n}\n\nlet assignedQueue = 'general';\n\nif (ai.category === 'billing') assignedQueue = 'billing';\nif (ai.category === 'bug' || ai.category === 'integration') assignedQueue = 'technical';\nif (ai.category === 'account_access') assignedQueue = 'accounts';\nif (score >= 80) assignedQueue = 'priority';\n\nconst slaHours =\n  score >= 80 ? 1 :\n  score >= 55 ? 4 :\n  score >= 30 ? 24 : 72;\n\nconst slaDueMs = original.submitted_at_epoch_ms + slaHours * 60 * 60 * 1000;\n\nreturn {\n  json: {\n    ...original,\n    ...ai,\n    priority_score: score,\n    assigned_queue: assignedQueue,\n    status: score >= 80 ? 'escalated' : 'queued',\n    escalated: score >= 80,\n    sla_due_iso: new Date(slaDueMs).toISOString(),\n    sla_due_epoch_ms: slaDueMs\n  }\n};\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1488,
        256
      ],
      "id": "82199c0f-717f-4778-a4ce-ddebea723ff1",
